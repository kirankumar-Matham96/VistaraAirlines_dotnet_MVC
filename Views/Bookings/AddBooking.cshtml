@model VistaraAirLinesApp.Models.ViewModels.BookingsViewModel

@{
    ViewBag.Title = "Add Booking";
}

<h2>Add Booking</h2>

@using (Html.BeginForm())
{
    @Html.HiddenFor(m => m.FlightId)
    @Html.HiddenFor(m => m.TravelDate)
    @Html.HiddenFor(m => m.EconomyFare)
    @Html.HiddenFor(m => m.BusinessFare)
    @Html.HiddenFor(m => m.ExecutiveFare)

    <span>@Html.ValidationSummary("", new { @class = "text-danger" })</span>

    <div class="form-group">
        <label>Flight Id</label>
        <input type="text" value="@Model.FlightId" class="form-control" readonly />
    </div>

    <div class="form-group">
        <label>Travel Date</label>
        <input type="text" value="@Model.TravelDate.ToShortDateString()" class="form-control" readonly />
    </div>

    <hr />

    <h3>Passenger Details</h3>

    <div id="passenger-container" class="container">
        @{
            ViewBag.index = 0;
        }

        @Html.Partial("_PassengerFormPartial", new VistaraAirLinesApp.Models.ViewModels.PassengerViewModel())
    </div>

    <div class="card p-3 mt-4">
        <h3>Booking Summary</h3>
        <hr />
        <p><strong>Passengers:</strong><span id="summary-passenger-count"></span></p>
        <p><strong>Base Fare:</strong> ₹<span id="summary-base-fare">0</span></p>
        <p><strong>GST (@ViewBag.GST_PERCENT%):</strong> ₹<span id="summary-gst">0</span></p>
        <hr />
        <h4>Total : ₹<span id="summary-total">0</span></h4>
    </div>

    <button type="button" class="btn btn-secondary" id="add-passenger-btn">➕ Add Passenger</button>

    // HIDDEN TEMPLATE
    <script type="text/template" id="passenger-template">
        @{
            ViewBag.Index = "__index__";
        }

        @Html.Partial(
            "_PassengerFormPartial",
            new VistaraAirLinesApp.Models.ViewModels.PassengerViewModel()
        )
    </script>

    <div class="mt-3">
        <button type="submit" class="btn btn-primary">
            Create Booking
        </button>

        @Html.ActionLink("Cancel", "SearchFlights", "Bookings", null, new { @class = "btn btn-secondary ms-2", onclick = "return confirm('Cancel current booking process?');" })
    </div>
}
<script src="~/Scripts/jquery-3.7.1.js"></script>
<script>
    const GST_PERCENT = 10;

    $(document).ready(function () {

        let passengerIndex = 1;
        updatePassengerTitles();
        updateBookingSummary();

        $(document).on("change", "select", function () { updateBookingSummary(); });

        //---------------------------------------
        // ADD PASSENGER
        //---------------------------------------
        $("#add-passenger-btn").click(function () {
            let template = $("#passenger-template").html();
            template = template.replace(/__index__/g, passengerIndex);

            $("#passenger-container").append(template);

            passengerIndex++;
            updatePassengerTitles();
        });

        //---------------------------------------
        // REMOVE PASSENGER
        //---------------------------------------
        $(document).on("click", ".remove-passenger-btn",
            function () {
                if ($(".passenger-block").length > 1) {
                    $(this).closest(".passenger-block").remove();
                    reIndexPassengers();
                    updatePassengerTitles();
                }
                else {
                    alert("At least one passenger is required.");
                }

                reIndexPassengers();
                updatePassengerTitles();
                updateBookingSummary();
            });

        //---------------------------------------
        // UPDATE PASSENGER TITLES
        //---------------------------------------
        function updatePassengerTitles() {
            $(".passenger-block").each(function (index) {
                $(this).find(".passenger-title").text("Passenger " + (index + 1));
            });
        }

        /***********/
        function updateBookingSummary() {
            //------------------------------------
            // GET FARES
            //------------------------------------
            let economyFare = parseFloat($("#EconomyFare").val()) || 0;
            let businessFare = parseFloat($("#BusinessFare").val()) || 0;
            let executiveFare = parseFloat($("#ExecutiveFare").val()) || 0;

            //------------------------------------
            // CALCULATE
            //------------------------------------
            let passengerCount = 0;
            let baseFare = 0;

            $(".passenger-block").each(function () {
                let selectedClass = $(this).find("select").val();

                if (selectedClass) {
                    passengerCount++;
                    switch (selectedClass) {
                        case "ECONOMY":
                            baseFare += economyFare;
                            break;
                        case "BUSINESS":
                            baseFare += businessFare;
                            break;
                        case "EXECUTIVE":
                            baseFare += executiveFare;
                            break;
                    }
                }
            });

            //------------------------------------
            // GST
            //------------------------------------
            let gstAmount = (baseFare * @ViewBag.GST_PERCENT) / 100;

            //------------------------------------
            // TOTAL
            //------------------------------------
            let total = baseFare + gstAmount;

            //------------------------------------
            // UPDATE UI
            //------------------------------------
            $("#summary-passenger-count").text(passengerCount);
            $("#summary-base-fare").text(baseFare.toFixed(2));
            $("#summary-gst").text(gstAmount.toFixed(2));
            $("#summary-total").text(total.toFixed(2));
        }
        /***********/

        //---------------------------------------
        // REINDEX INPUT NAMES
        //---------------------------------------
        function reIndexPassengers() {
            $(".passenger-block").each(function (newIndex) {

                //-----------------------------------
                // UPDATE INPUTS + SELECTS
                //-----------------------------------
                $(this).find("input, select").each(function () {

                    //-----------------------------------
                    // UPDATE NAME
                    //-----------------------------------

                    let currentName = $(this).attr("name");

                    if (currentName) {
                        let updatedName = currentName.replace(/PassengerList\[\d+\]/, "PassengerList[" + newIndex + "]");
                        $(this).attr("name", updatedName);
                    }
                    //-----------------------------------
                    // UPDATE ID
                    //-----------------------------------
                    let currentId = $(this).attr("id");

                    if (currentId) {
                        let updatedId = currentId.replace(/PassengerList_\d+__/, "PassengerList_" + newIndex + "__");
                        $(this).attr("id", updatedId);
                    }
                });
            });
        }
    });
</script>