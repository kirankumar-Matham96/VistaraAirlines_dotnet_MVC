@model IEnumerable<VistaraAirLinesApp.Models.ViewModels.BookingHistoryViewModel>

@{
    ViewBag.Title = "Booking History";
}

<div class="container">
    <h2>Booking History</h2>
    <hr />

    <div class="mb-3">
        @Html.ActionLink("Back To Flights", "SearchFlights", "Bookings", null, new { @class = "btn btn-primary" })
    </div>

    @if (!Model.Any())
    {
        <p>No bookings found.</p>
    }
    else
    {
        foreach (var booking in Model)
        {
            <div class="card p-3 mb-4">
                <h4>Booking #@booking.BookingId</h4>
                <hr />
                <p><strong>Flight:</strong> @booking.FlightCode-@booking.FlightName</p>
                <p><strong>Route:</strong> @booking.Source → @booking.Destination</p>
                <p><strong>Travel Date:</strong> @booking.TravelDate.ToShortDateString()</p>
                <p><strong>Passengers:</strong> @booking.PassengerCount</p>
                <p><strong>Total Fare:</strong> ₹@booking.TotalFare</p>
                <p><strong>Status:</strong> @booking.BookingStatus</p>
                <hr />
                <h5>Passenger Details</h5>

                <table class="table table-bordered">
                    <tr>
                        <th>Name</th>
                        <th>Seat No</th>
                        <th>Class</th>
                        <th>Email</th>
                        <th>Phone</th>
                    </tr>

                    @foreach (var passenger in booking.Passengers)
                    {
                        <tr>
                            <td>@passenger.FullName</td>
                            <td>@passenger.SeatNo</td>
                            <td>@passenger.Class</td>
                            <td>@passenger.Email</td>
                            <td>@passenger.Phone</td>
                        </tr>
                    }
                </table>

                <div class="mt-3">
                    @Html.ActionLink("View Ticket", "BookingDetails", new { id = booking.BookingId }, new { @class = "btn btn-primary" })

                    @*@Html.ActionLink("Cancel Booking", "CancelBooking", new { id = booking.BookingId }, new { @class = "btn btn-danger ms-2" });*@

                    @if (booking.BookingStatus == "CANCELLED")
                    {
                        <span class="btn btn-secondary ms-2 disabled">CANCELLED</span>
                    }
                    else
                    {
                        @Html.ActionLink("Cancel Booking", "CancelBooking", new { id = booking.BookingId }, new { @class = "btn btn-danger ms-2" })
                    }
                </div>
            </div>
        }
    }
</div>