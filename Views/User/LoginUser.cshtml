@model VistaraAirLinesApp.Models.ViewModels.LoginViewModel

@{
    ViewBag.Title = "LoginUser";
}

<div class="container d-flex flex-column align-items-center">
    <h2>Login User</h2>

    @using (Html.BeginForm(null, null, FormMethod.Post, new { @class = "card p-5" }))
    {
        @Html.AntiForgeryToken()
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

        <div class="row mb-3">
            @Html.LabelFor(model => model.UserId)
            <div class="col-md-9">
                @Html.EditorFor(model => model.UserId, new { htmlAttributes = new { @class = "form-control" } })
                @Html.ValidationMessageFor(model => model.UserId, "", new { @class = "text-danger" })
            </div>
        </div>

        <div class="row mb-3">
            @Html.LabelFor(model => model.Password)
            <div class="col-md-9">
                @Html.EditorFor(model => model.Password, new { htmlAttributes = new { @class = "form-control" } })
                @Html.ValidationMessageFor(model => model.Password, "", new { @class = "text-danger" })
            </div>
        </div>

        <div class="row mb-3">
            @Html.LabelFor(model => model.Role)
            <div class="col-md-9">
                @Html.RadioButtonFor(model => model.Role, "MANAGER", new { htmlAttributes = new { @class = "form-control" } }) Manager
                @Html.RadioButtonFor(model => model.Role, "EMPLOYEE", new { htmlAttributes = new { @class = "form-control" } }) Employee
                @Html.ValidationMessageFor(model => model.Role, "", new { @class = "text-danger" })
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-md-9">
                <button type="submit" class="btn btn-primary">Login</button>
            </div>
        </div>
    }
</div>

