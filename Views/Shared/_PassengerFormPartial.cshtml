
@model VistaraAirLinesApp.Models.ViewModels.PassengerViewModel

@{
    var index = ViewBag.Index;
}

<div class="passenger-block border p-3 mb-3">

    <div class="d-flex justify-content-between align-items-center">
        <h4 class="passenger-title">Passenger</h4>
        <button type="button" class="btn btn-danger remove-passenger-btn">Remove</button>
    </div>

    <div class="form-group">
        <label>Full Name</label>
        <input type="text" name="PassengerList[@index].FullName" class="form-control" />

    </div>

    <div class="form-group">
        <label>Address</label>
        <input type="text" name="PassengerList[@index].Address" class="form-control" />
    </div>

    <div class="form-group">
        <label>Phone</label>
        <input type="text" name="PassengerList[@index].Phone" class="form-control" />
    </div>

    <div class="form-group">
        <label>Email</label>
        <input type="email" name="PassengerList[@index].Email" class="form-control" />
    </div>

    <div class="form-group">
        <label>Seat No</label>
        <input type="text" name="PassengerList[@index].SeatNo" class="form-control" />
    </div>

    <div class="form-group">
        <label>Class</label>
        <select name="PassengerList[@index].Class" class="form-control">
            <option value="">Select Class</option>
            <option value="ECONOMY">ECONOMY</option>
            <option value="BUSINESS">BUSINESS</option>
            <option value="EXECUTIVE">EXECUTIVE</option>
        </select>
    </div>


</div>